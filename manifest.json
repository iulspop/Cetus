{
    "name": "Cetus",
    "version": "1.05",
    "description": "Dynamic analysis extension for WASM",
    "manifest_version": 3,
    "content_scripts": [
        {
            "js": ["shared/contentutils.js"],
            "matches": ["<all_urls>"],
            "all_frames": true,
            "run_at": "document_start"
        },
        {
            "js": ["content/content.js"],
            "matches": ["<all_urls>"],
            "all_frames": true,
            "run_at": "document_start"
        },
        {
            "js": [
                "shared/utils.js",
                "shared/WAIL/wail.js",
                "content/thirdparty/stacktrace/stacktrace.min.js",
                "content/cetus.js",
                "content/init.js"
            ],
            "matches": ["<all_urls>"],
            "all_frames": true,
            "run_at": "document_start",
            "world": "MAIN"
        }
    ],
    "permissions": ["activeTab", "storage"],
    "content_security_policy": {
        "extension_pages": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline';"
    },
    "web_accessible_resources": [],
    "action": {
        "default_title": "Cetus",
        "default_popup": "extension/popupview.html"
    },
    "devtools_page": "extension/devtools.html",
    "background": {
        "service_worker": "extension/background.js"
    },
    "icons": {
        "16": "icons/cetus16.png",
        "48": "icons/cetus48.png",
        "128": "icons/cetus128.png"
    },
    "options_ui": {
        "page": "extension/options.html",
        "open_in_tab": false
    }
}
